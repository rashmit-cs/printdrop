generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Shop {
  id             String   @id @default(uuid())
  name           String
  ownerName      String
  email          String   @unique
  passwordHash   String
  phone          String
  upiId          String?  // e.g. rajesh@paytm — customer pays here directly
  colorPrice     Float    @default(10)
  bwPrice        Float    @default(2)
  isOpen         Boolean  @default(true)
  qrGenerated    Boolean  @default(false)
  agentSecret    String   @default(uuid()) // unique per-shop agent secret
  createdAt      DateTime @default(now())
  orders         Order[]
  printers       Printer[]
}

model Printer {
  id        String      @id @default(uuid())
  shopId    String
  shop      Shop        @relation(fields: [shopId], references: [id])
  name      String
  type      PrinterType @default(BOTH)
  isDefault Boolean     @default(false)
  isOnline  Boolean     @default(true)
  lastSeen  DateTime    @default(now())
  createdAt DateTime    @default(now())
}

enum PrinterType {
  COLOR
  BW
  BOTH
}

model Order {
  id                    String      @id @default(uuid())
  shopId                String
  shop                  Shop        @relation(fields: [shopId], references: [id])
  fileName              String
  fileUrl               String
  filePath              String
  printType             PrintType
  pages                 Int         @default(1)
  copies                Int         @default(1)
  amount                Float
  status                OrderStatus @default(PENDING_PAYMENT)
  customerClaimedPaidAt DateTime?
  confirmedAt           DateTime?
  printerId             String?
  customerPhone         String?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  printedAt             DateTime?
  deletedAt             DateTime?
}

enum PrintType {
  COLOR
  BW
}

enum OrderStatus {
  PENDING_PAYMENT
  AWAITING_CONFIRMATION
  PAID
  PRINTING
  PRINTED
  FAILED
  REJECTED
}
